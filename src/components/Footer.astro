---
const year = new Date().getFullYear();
const raw  = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href={base} class="footer-logo">LB</a>
      <p class="footer-tagline">Visual identity · Illustration · Print design</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={`${base}portfolio`}>Work</a>
      <a href={`${base}about`}>About</a>
      <a href={`${base}services`}>Services</a>
      <a href={`${base}contact`}>Contact</a>
    </nav>

    <div class="footer-right">
      <div class="footer-social">
        <a href="#" aria-label="Instagram" class="social-link">Instagram</a>
        <a href="#" aria-label="Behance"   class="social-link">Behance</a>
      </div>
      <p class="footer-copy">&copy; {year} Turcsik Bella</p>
    </div>
  </div>

  <div class="footer-bar">
    <span style="flex:3;background:var(--sky)"></span>
    <span style="flex:1;background:var(--earth)"></span>
    <span style="flex:1;background:var(--forest)"></span>
    <span style="flex:0.5;background:var(--red)"></span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    padding-block: 3rem;
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 500;
    color: var(--sky-dark);
    text-decoration: none;
    line-height: 1;
    display: block;
    margin-bottom: 0.4rem;
  }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-light);
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-nav a {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--sky-dark); }

  .footer-right {
    text-align: right;
  }

  .footer-social {
    display: flex;
    gap: 1.5rem;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .social-link {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .social-link:hover { color: var(--sky-dark); }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    color: var(--text-light);
  }

  .footer-bar {
    display: flex;
    height: 4px;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-right { text-align: center; }
    .footer-social { justify-content: center; }
    .footer-nav { flex-direction: row; flex-wrap: wrap; justify-content: center; }
  }
</style>
