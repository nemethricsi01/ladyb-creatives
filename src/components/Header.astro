---
const base = '/';
const path = Astro.url.pathname;

function isActive(segment: string) {
  return path.includes(segment);
}
---

<header class="header">
  <div class="header-inner">
    <nav class="nav nav-left" aria-label="Main navigation">
      <a href={base} class:list={['nav-link', { active: path === base }]}>Home</a>
      <a href={`${base}portfolio`} class:list={['nav-link', { active: isActive('portfolio') }]}>Work</a>
    </nav>

    <a href={base} class="logo" aria-label="Ladyb Creatives — home">
      <img src={`${base}logomark_ladyb2.svg`} alt="" class="logo-img" aria-hidden="true" />
    </a>

    <nav class="nav nav-right" aria-label="Secondary navigation">
      <a href={`${base}about`}   class:list={['nav-link', { active: isActive('about') }]}>About</a>
      <a href={`${base}contact`} class:list={['nav-link', 'nav-cta', { active: isActive('contact') }]}>Contact</a>
    </nav>

    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const navs   = document.querySelectorAll<HTMLElement>('.nav');

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    navs.forEach((nav) => nav.classList.toggle('nav-open', !open));
  });
</script>

<style>
  .header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    overflow: visible;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2.5rem;
    height: var(--nav-height);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .logo-img {
    width: 90px;
    height: auto;
    flex-shrink: 0;
  }

  /* Nav */
  .nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-left  { justify-content: flex-start; }
  .nav-right { justify-content: flex-end; }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text);
    position: relative;
    padding-bottom: 3px;
    transition: color 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    inset-block-end: 0;
    inset-inline-start: 0;
    width: 0;
    height: 1px;
    background: var(--red);
    transition: width 0.25s var(--ease);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-cta {
    padding: 0.55rem 1.2rem;
    border: 1px solid var(--border);
    color: var(--text);
    transition: border-color 0.2s, color 0.2s;
  }
  .nav-cta::after { display: none; }
  .nav-cta:hover  { border-color: var(--red); color: var(--red); }
  .nav-cta.active { border-color: var(--red); color: var(--red); }

  /* Hamburger (mobile) */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .menu-toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--text);
    transition: transform 0.2s;
  }

  @media (max-width: 768px) {
    .header-inner {
      height: auto;
      min-height: var(--nav-height);
      align-items: start;
      padding: 0 1.5rem;
    }

    .menu-toggle {
      display: flex;
      align-self: start;
      margin-block-start: calc((var(--nav-height) - 22px) / 2);
    }

    .logo {
      align-self: start;
      padding-block-start: calc((var(--nav-height) - 83px) / 2);
    }

    .nav {
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding-block: 1.25rem;
    }
    .nav-right { align-items: flex-end; }
    .nav.nav-open { display: flex; }

    .nav-link {
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
      width: 100%;
    }
    .nav-right .nav-link { text-align: right; }
    .nav-cta { border: none; padding: 0.75rem 0; }
  }
</style>
