---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = '/';

const nameLine1 = 'BELLA'.split('');
const nameLine2 = 'TURCSIK'.split('');
const tileRotations = [-4, 3, -2, 4, -3, 2, -4];

const marqueeWords = ['Pop Art', 'Graphic Design', 'Illustration', 'Print', 'Budapest'];

const featuredWork = [
  {
    title: 'Horizon Studio',
    category: 'Branding & Identity',
    year: '2024',
    palette: ['#7AAFCB', '#1C1C1C', '#E8B923', '#F7F5F0'],
  },
  {
    title: 'Reverie',
    category: 'Illustration',
    year: '2024',
    palette: ['#2B4B3F', '#C94030', '#F7F5F0', '#E8B923'],
  },
  {
    title: 'Almanach',
    category: 'Print & Editorial',
    year: '2023',
    palette: ['#C4A882', '#1C1C1C', '#C94030', '#7AAFCB'],
  },
];
---

<BaseLayout title="Home">

  <!-- ── Hero ──────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="speech-bubble" aria-hidden="true">
      <p>wdym <em>"just make it pop"</em>?</p>
    </div>

    <div class="hero-content">
      <span class="label hero-label-pop">Graphic Designer <span aria-hidden="true">|</span> Illustrator</span>

      <h1 class="ransom-name">
        <span class="ransom-word">
          {nameLine1.map((ch, i) => (
            <span class="tile" style={`--r:${tileRotations[i % tileRotations.length]}deg`}>{ch}</span>
          ))}
        </span>
        <span class="ransom-word">
          {nameLine2.map((ch, i) => (
            <span class="tile" style={`--r:${tileRotations[(i + 2) % tileRotations.length]}deg`}>
              {ch}
              {ch === 'C' && <span class="tile-copy" aria-hidden="true">©</span>}
            </span>
          ))}
        </span>
      </h1>

      <p class="hero-tagline-pop">
        I enjoy experimenting with different styles, techniques
        and mediums to create work that fits the idea.
      </p>

      <div class="hero-actions-pop">
        <a href={`${base}portfolio`} class="btn btn-pop-primary">Explore Projects →</a>
        <a href={`${base}about`} class="btn btn-pop-ghost">About Me</a>
      </div>
    </div>
  </section>

  <!-- ── Info Strip ────────────────────────────────────────────────── -->
  <section class="hero-strip">
    <div class="container strip-inner">
      <span>Branding · Packaging · Print · Illustration</span>
      <span>Based in Budapest · Available Worldwide</span>
    </div>
  </section>

  <!-- ── Selected Work ─────────────────────────────────────────────── -->
  <section class="section section-work reveal">
    <div class="container">
      <div class="section-header">
        <span class="label">Selected Work</span>
        <a href={`${base}portfolio`} class="link-arrow">All Projects →</a>
      </div>

      <div class="featured-grid">
        {featuredWork.map((item) => (
          <a href={`${base}portfolio`} class="feat-card">
            <div class="card-visual">
              {item.palette.map((color, i) => (
                <div
                  class="cv-quad"
                  style={`--quad-bg:${color};--quad-bg-alt:${item.palette[(i + 2) % item.palette.length]};--quad-fg:${item.palette[(i + 1) % item.palette.length]};`}
                >
                  <span class="cv-dot"></span>
                </div>
              ))}
            </div>
            <div class="card-meta">
              <span class="label card-cat">{item.category}</span>
              <h3 class="card-title">{item.title}</h3>
              <span class="card-year">{item.year}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Marquee ───────────────────────────────────────────────────── -->
  <section class="marquee reveal" aria-hidden="true">
    <div class="marquee-track">
      {Array(8).fill(marqueeWords).flat().map((word) => (
        <>
          <span class="marquee-word">{word}</span>
          <span class="marquee-star">✦</span>
        </>
      ))}
    </div>
  </section>

  <!-- ── About Teaser ──────────────────────────────────────────────── -->
  <section class="section section-about reveal">
    <div class="container about-split">
      <div class="about-visual" aria-hidden="true">
        <div class="av-frame">
          <div class="av-sky"></div>
          <div class="av-circle"></div>
          <div class="av-line"></div>
        </div>
      </div>

      <div class="about-text">
        <span class="label">About</span>
        <h2 class="about-heading">
          Design is a <em>conversation</em><br />between form,<br />colour, and meaning.
        </h2>
        <p>
          Turcsik Bella is a Budapest-based graphic designer working at the
          intersection of visual identity and conceptual illustration. Drawn to
          the surreal clarity of Magritte and the bold, repeatable pop of
          Warhol, her work finds poetry in structure.
        </p>
        <a href={`${base}about`} class="btn btn-ghost" style="margin-top:2rem">Read More</a>
      </div>
    </div>
  </section>

  <!-- ── Services Teaser ───────────────────────────────────────────── -->
  <section class="section section-services reveal">
    <div class="container">
      <div class="section-header">
        <span class="label">What I Do</span>
        <a href={`${base}services`} class="link-arrow">All Services →</a>
      </div>
      <div class="services-row">
        <div class="svc-item">
          <div class="svc-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="1.5"/>
              <line x1="14" y1="24" x2="34" y2="24" stroke="currentColor" stroke-width="1.5"/>
              <line x1="24" y1="14" x2="24" y2="34" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Visual Identity</h3>
          <p>Brand systems that speak with coherence and quiet confidence.</p>
        </div>
        <div class="svc-item">
          <div class="svc-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="6" width="36" height="36" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="24" cy="24" r="10" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Illustration</h3>
          <p>Original images that inhabit the space between thought and vision.</p>
        </div>
        <div class="svc-item">
          <div class="svc-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="8" y="4" width="32" height="40" rx="1" stroke="currentColor" stroke-width="1.5"/>
              <line x1="15" y1="16" x2="33" y2="16" stroke="currentColor" stroke-width="1.5"/>
              <line x1="15" y1="23" x2="33" y2="23" stroke="currentColor" stroke-width="1.5"/>
              <line x1="15" y1="30" x2="25" y2="30" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Print & Editorial</h3>
          <p>Posters, books, and publications designed for the page.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Contact CTA ───────────────────────────────────────────────── -->
  <section class="section section-cta reveal">
    <div class="container">
      <div class="cta-inner">
        <span class="label">Let's Talk</span>
        <h2 class="cta-heading">Have a project in mind?</h2>
        <a href="mailto:bella@ladybcreatives.com" class="cta-email">
          bella@ladybcreatives.com
        </a>
        <a href={`${base}contact`} class="btn btn-dark">Get in Touch</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Hero ───────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: var(--nav-height);
    min-height: clamp(560px, 90vh, 820px);
    display: flex;
    align-items: center;
    background-image: url('/kep_01.png');
    background-size: cover;
    background-position: right center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, rgba(15,13,12,0.62) 0%, rgba(15,13,12,0.25) 45%, transparent 68%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  .hero-label-pop {
    color: var(--pop-yellow);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .ransom-name {
    margin: 0.75rem 0 1.75rem;
  }

  .ransom-word {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .tile {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--cloud);
    color: var(--bg-dark);
    border: 2px solid var(--bg-dark);
    font-family: var(--font-ransom);
    font-weight: 400;
    font-size: clamp(2.2rem, 6vw, 4.6rem);
    line-height: 1;
    padding: 0.12em 0.22em 0.06em;
    transform: rotate(var(--r));
    box-shadow: 3px 3px 0 rgba(0,0,0,0.35);
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }

  .tile:hover {
    transform: rotate(calc(var(--r) * -1.4)) translateY(-5px) scale(1.06);
    box-shadow: 6px 7px 0 rgba(0,0,0,0.4);
    z-index: 2;
  }

  .tile:has(.tile-copy) { z-index: 1; }

  .tile-copy {
    position: absolute;
    z-index: 1;
    inset-block-start: -0.35em;
    inset-inline-end: -0.35em;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.7em;
    height: 1.7em;
    border-radius: 50%;
    background: var(--red);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.26em;
    font-weight: 600;
    box-shadow: 1px 1px 0 rgba(0,0,0,0.4);
  }

  .hero-tagline-pop {
    font-size: 1rem;
    color: var(--cloud);
    max-width: 38ch;
    line-height: 1.65;
    margin-bottom: 2.25rem;
    font-weight: 300;
  }

  .hero-actions-pop {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-pop-primary {
    background: var(--red);
    border-color: var(--red);
    border-radius: 999px;
    color: #fff;
  }
  .btn-pop-primary:hover {
    background: #A5311F;
    border-color: #A5311F;
  }

  .btn-pop-ghost {
    background: transparent;
    border-color: var(--cloud);
    border-radius: 999px;
    color: var(--cloud);
  }
  .btn-pop-ghost:hover {
    background: var(--cloud);
    color: var(--bg-dark);
  }

  /* Speech bubble */
  .speech-bubble {
    position: absolute;
    z-index: 2;
    inset-block-start: 16%;
    inset-inline-end: 6%;
    max-width: 230px;
    background: var(--cloud);
    border-radius: 18px;
    padding: 0.85rem 1.15rem;
    transform: rotate(-3deg);
    box-shadow: 3px 4px 0 rgba(0,0,0,0.4);
  }

  .speech-bubble::after {
    content: '';
    position: absolute;
    inset-block-end: -9px;
    inset-inline-start: 30px;
    width: 0;
    height: 0;
    border: 10px solid transparent;
    border-block-start-color: var(--cloud);
    border-block-end: 0;
  }

  .speech-bubble p {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--red);
  }

  /* ─── Info Strip ─────────────────────────────────────────────────── */
  .hero-strip {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .strip-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 2rem;
    padding-block: 1.1rem;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
  }

  /* ─── Marquee ────────────────────────────────────────────────────── */
  .marquee {
    overflow: hidden;
    background: var(--bg-dark);
    border-block: 3px solid var(--bg-dark);
    padding-block: 1rem;
  }

  .marquee-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: marquee-scroll 70s linear infinite;
  }

  .marquee-word {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pop-yellow);
    white-space: nowrap;
    margin-inline-end: 1.5rem;
  }

  .marquee-star {
    color: var(--red);
    font-size: 1rem;
    margin-inline-end: 1.5rem;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }

  /* ─── Featured Work ──────────────────────────────────────────────── */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feat-card {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .card-visual {
    position: relative;
    aspect-ratio: 4 / 5;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 3px;
    background: var(--bg-dark);
    border: 3px solid var(--bg-dark);
    overflow: hidden;
    margin-bottom: 1.25rem;
    transition: transform 0.4s var(--ease);
  }

  .feat-card:hover .card-visual { transform: translateY(-4px); }

  .cv-quad {
    position: relative;
    background: var(--quad-bg);
    overflow: hidden;
    pointer-events: none;
  }

  .cv-quad::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--quad-bg-alt);
    opacity: 0;
    transition: opacity 0.35s var(--ease);
  }

  .feat-card:hover .cv-quad::before { opacity: 1; }
  .cv-quad:nth-child(2)::before { transition-delay: 0.06s; }
  .cv-quad:nth-child(3)::before { transition-delay: 0.12s; }
  .cv-quad:nth-child(4)::before { transition-delay: 0.18s; }

  .cv-dot {
    position: absolute;
    z-index: 1;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    transform: translate(-50%, -50%);
    width: 46%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--quad-fg);
    opacity: 0.85;
  }

  .card-meta { padding: 0 0.25rem; }

  .card-cat {
    display: block;
    margin-bottom: 0.35rem;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 400;
    margin-bottom: 0.25rem;
    transition: color 0.2s;
  }
  .feat-card:hover .card-title { color: var(--red); }

  .card-year {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-light);
  }

  /* ─── About Teaser ───────────────────────────────────────────────── */
  .section-about { background: var(--bg-alt); }

  .about-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  /* Magritte-inspired frame within a frame */
  .about-visual { position: relative; }

  .av-frame {
    position: relative;
    aspect-ratio: 3 / 4;
    background: var(--sky);
    border: 3px solid var(--bg-dark);
    overflow: hidden;
  }

  .av-sky {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      var(--sky-light) 0%,
      var(--sky) 50%,
      var(--sky-dark) 100%
    );
  }

  .av-circle {
    position: absolute;
    inset-block-end: -10%;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    width: 70%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--earth);
  }

  .av-line {
    position: absolute;
    inset-block-start: 38%;
    inset-inline: 0;
    height: 1px;
    background: rgba(255,255,255,0.35);
  }

  .about-text .label { margin-bottom: 1.5rem; }

  .about-heading {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .about-heading em {
    font-style: italic;
    color: var(--red);
  }

  .about-text p {
    color: var(--text-muted);
    font-size: 0.95rem;
    max-width: 42ch;
  }

  /* ─── Services ───────────────────────────────────────────────────── */
  .services-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .svc-item { padding-top: 1.5rem; border-top: 3px solid var(--bg-dark); }

  .svc-icon {
    width: 48px;
    height: 48px;
    color: var(--red);
    margin-bottom: 1.25rem;
  }

  .svc-item h3 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    margin-bottom: 0.6rem;
  }

  .svc-item p {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 300;
  }

  /* ─── CTA ────────────────────────────────────────────────────────── */
  .section-cta { background: var(--bg-dark); color: var(--cloud); }
  .section-cta .label { color: var(--pop-yellow); margin-bottom: 1rem; }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .cta-heading {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--cloud);
  }

  .cta-email {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: 300;
    color: var(--pop-yellow);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }
  .cta-email:hover { color: var(--red); }

  .section-cta .btn-dark {
    background: var(--red);
    border-color: var(--red);
    border-radius: 999px;
    color: #fff;
  }
  .section-cta .btn-dark:hover {
    background: #A5311F;
    border-color: #A5311F;
  }

  /* ─── Responsive ─────────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .speech-bubble { display: none; }
    .featured-grid { grid-template-columns: 1fr; gap: 2rem; }
    .about-split { grid-template-columns: 1fr; }
    .av-frame { aspect-ratio: 16 / 9; }
    .services-row { grid-template-columns: 1fr; gap: 2rem; }
  }

  @media (max-width: 768px) {
    .hero-content { padding: 0 1.5rem; }
    .tile { font-size: clamp(1.9rem, 10vw, 3rem); }
    .strip-inner { flex-direction: column; align-items: flex-start; }
    .featured-grid { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
  }
</style>
