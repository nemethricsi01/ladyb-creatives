---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Turcsik Bella — Ladyb Creatives, Budapest graphic designer.">

  <div class="page-wrap">

    <section class="contact-section">
      <div class="container cs-inner">

        <!-- Left: Text -->
        <div class="cs-text">
          <span class="label">Contact</span>
          <h1 class="cs-title">
            Let's make<br />something<br /><em>together.</em>
          </h1>
          <p class="cs-desc">
            Whether you have a brief ready or just an idea, I'd love to
            hear from you. I'm available for freelance projects, collaborations,
            and commissions.
          </p>

          <div class="cs-email-wrap">
            <span class="label" style="margin-bottom:0.75rem">Email</span>
            <a href="mailto:bella@ladybcreatives.com" class="cs-email">
              bella@ladybcreatives.com
            </a>
          </div>

          <div class="cs-social">
            <span class="label" style="margin-bottom:0.75rem">Find me on</span>
            <div class="social-links">
              <a href="#" class="social-item" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="2" width="20" height="20" rx="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="0.75" fill="currentColor" stroke="none"/>
                </svg>
                Instagram
              </a>
              <a href="#" class="social-item" aria-label="Behance">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 7h7.5C11.4 7 13 8.6 13 10.5S11.4 14 9.5 14H2V7z"/>
                  <path d="M2 14h8.5C12.4 14 14 15.4 14 17.3S12.4 20 10.5 20H2v-6z"/>
                  <line x1="15" y1="9" x2="22" y2="9"/>
                  <path d="M22 14c0 2.8-2.2 5-5 5s-5-2.2-5-5 2.2-5 5-5 5 2.2 5 5z"/>
                </svg>
                Behance
              </a>
              <a href="#" class="social-item" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="2" width="20" height="20" rx="3"/>
                  <line x1="7" y1="11" x2="7" y2="17"/>
                  <line x1="7" y1="7" x2="7" y2="8"/>
                  <path d="M11 17v-4c0-1.1.9-2 2-2h1c1.1 0 2 .9 2 2v4"/>
                  <line x1="11" y1="11" x2="11" y2="17"/>
                </svg>
                LinkedIn
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Visual -->
        <div class="cs-visual" aria-hidden="true">
          <div class="cv-sky-rect">
            <div class="cvs-cloud"></div>
            <div class="cvs-line"></div>
          </div>
          <div class="cv-earth-circle"></div>
          <div class="cv-dot cv-dot-1"></div>
          <div class="cv-dot cv-dot-2"></div>
          <div class="cv-label-geo">
            <span class="label" style="color:rgba(255,255,255,0.5);">Budapest</span>
          </div>
        </div>

      </div>
    </section>

    <!-- Footer note -->
    <div class="avail-banner">
      <div class="container ab-inner">
        <div class="ab-dot" aria-hidden="true"></div>
        <p>
          <strong>Currently available</strong> for new projects starting
          <span class="label" style="display:inline;letter-spacing:0.12em">Q3 2026</span>
        </p>
      </div>
    </div>

  </div>

</BaseLayout>

<style>
  .page-wrap { padding-top: var(--nav-height); min-height: 100vh; display: flex; flex-direction: column; }

  /* ─── Contact Section ──────────────────────────────────── */
  .contact-section {
    flex: 1;
    padding: 6rem 0 5rem;
  }

  .cs-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    min-height: 70vh;
  }

  /* Left text */
  .cs-text .label { margin-bottom: 1.5rem; }

  .cs-title {
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
  }
  .cs-title em { color: var(--sky-dark); }

  .cs-desc {
    color: var(--text-muted);
    font-size: 1rem;
    font-weight: 300;
    max-width: 40ch;
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .cs-email-wrap {
    margin-bottom: 2.5rem;
  }

  .cs-email {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 400;
    text-decoration: none;
    color: var(--sky-dark);
    letter-spacing: 0.01em;
    display: inline-block;
    position: relative;
    padding-bottom: 3px;
    transition: color 0.2s;
  }

  .cs-email::after {
    content: '';
    position: absolute;
    inset-block-end: 0;
    inset-inline-start: 0;
    width: 100%;
    height: 1px;
    background: var(--sky-dark);
    transform: scaleX(0.3);
    transform-origin: left;
    transition: transform 0.3s var(--ease);
  }

  .cs-email:hover { color: var(--forest); }
  .cs-email:hover::after { transform: scaleX(1); background: var(--forest); }

  .cs-social .label { margin-bottom: 1rem; }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .social-item:hover { color: var(--sky-dark); }

  .social-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* Right visual — Magritte sky with geometric Bauhaus shapes */
  .cs-visual {
    position: relative;
    aspect-ratio: 1;
  }

  .cv-sky-rect {
    position: absolute;
    inset-block-start: 0;
    inset-inline-end: 0;
    width: 85%;
    height: 75%;
    background: linear-gradient(to bottom, #B8D8E8 0%, #7AAFCB 60%, #4A7D9A 100%);
    overflow: hidden;
  }

  .cvs-cloud {
    position: absolute;
    inset-block-start: 25%;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    width: 55%;
    height: 20%;
    border-radius: 100px;
    background: rgba(255,255,255,0.25);
  }

  .cvs-line {
    position: absolute;
    inset-block-end: 30%;
    inset-inline: 0;
    height: 1px;
    background: rgba(255,255,255,0.2);
  }

  .cv-earth-circle {
    position: absolute;
    inset-block-end: 0;
    inset-inline-start: 0;
    width: 50%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--earth);
    opacity: 0.9;
  }

  .cv-dot {
    position: absolute;
    border-radius: 50%;
  }

  .cv-dot-1 {
    width: 12px;
    height: 12px;
    background: var(--red);
    inset-block-start: 5%;
    inset-inline-start: 5%;
  }

  .cv-dot-2 {
    width: 8px;
    height: 8px;
    background: var(--forest);
    inset-block-end: 20%;
    inset-inline-end: 5%;
  }

  .cv-label-geo {
    position: absolute;
    inset-block-end: 1rem;
    inset-inline-end: 1rem;
  }

  /* ─── Availability Banner ──────────────────────────────── */
  .avail-banner {
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
  }

  .ab-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-block: 1.5rem;
  }

  .ab-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4CAF70;
    flex-shrink: 0;
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .ab-inner p {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 300;
  }
  .ab-inner strong { color: var(--text); font-weight: 500; }

  /* ─── Responsive ───────────────────────────────────────── */
  @media (max-width: 960px) {
    .cs-inner { grid-template-columns: 1fr; gap: 4rem; }
    .cs-visual { aspect-ratio: 4/3; }
  }
  @media (max-width: 560px) {
    .cs-visual { display: none; }
  }
</style>
